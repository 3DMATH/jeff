# ============================================================
# ADMIN (destructive -- behind glass)
# ============================================================

cmd_admin() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "${subcmd}" in
        flash)  cmd_admin_flash "$@" ;;
        init)   cmd_admin_init "$@" ;;
        "")
            echo ""
            echo -e "  ${C_BOLD}Jeff Admin${C_RESET} ${C_DIM}(destructive operations)${C_RESET}"
            echo ""
            echo "  jeff admin flash <disk>   Erase disk + burn fresh chip"
            echo "  jeff admin init <path>    Burn chip on formatted volume"
            echo ""
            ;;
        *)
            fail "Unknown admin command: ${subcmd}"
            echo "  Available: flash, init"
            exit 1
            ;;
    esac
}

cmd_admin_flash() {
    local disk="${1:?Usage: jeff admin flash /dev/diskN [--label NAME] [--size 8g]}"
    shift

    local label="" vault_size="8g" model_name="qwen2.5:7b-instruct-q4_K_M"

    # Try to detect existing volume name
    local existing
    existing=$(diskutil info "${disk}" 2>/dev/null | grep "Volume Name" | sed 's/.*: *//' | tr -d ' ' || echo "")
    if [[ -z "${existing}" ]] || [[ "${existing}" == "Notapplicable" ]]; then
        existing=$(diskutil list "${disk}" 2>/dev/null | grep -oE '[A-Z][A-Z0-9_-]+' | head -1 || echo "")
    fi

    label="${existing:-Chip}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --label)  label="$2"; shift 2 ;;
            --size)   vault_size="$2"; shift 2 ;;
            --model)  model_name="$2"; shift 2 ;;
            *)        echo "Unknown arg: $1"; exit 1 ;;
        esac
    done

    # Validation
    if [[ ! -e "${disk}" ]]; then
        fail "${disk} does not exist"
        exit 1
    fi

    local boot_disk
    boot_disk=$(diskutil info / 2>/dev/null | grep "Part of Whole" | awk '{print $NF}')
    if [[ "${disk}" == *"${boot_disk}"* ]]; then
        fail "Refusing to format the boot disk"
        exit 1
    fi

    echo ""
    echo -e "  ${C_RED}╔══════════════════════════════════════════════╗${C_RESET}"
    echo -e "  ${C_RED}║  DESTRUCTIVE: This will ERASE ${disk}  ║${C_RESET}"
    echo -e "  ${C_RED}║  All data will be permanently lost.          ║${C_RESET}"
    echo -e "  ${C_RED}╚══════════════════════════════════════════════╝${C_RESET}"
    echo ""
    diskutil info "${disk}" 2>/dev/null | grep -E "Device Node|Device / Media Name|Disk Size|Volume Name" | sed 's/^/  /'
    echo ""
    echo "  Label:   ${label}"
    echo "  Vault:   ${vault_size}"
    echo ""

    # Require typing the disk identifier to confirm (not just YES)
    local disk_short
    disk_short=$(basename "${disk}")
    echo -e "  Type ${C_BOLD}ERASE ${disk_short}${C_RESET} to confirm:"
    read -rp "  > " CONFIRM
    echo ""
    if [[ "${CONFIRM}" != "ERASE ${disk_short}" ]]; then
        echo "  Aborted."
        exit 1
    fi

    # Erase
    echo "  [1/2] Erasing ${disk}..."
    diskutil eraseDisk ExFAT "${label}" GPT "${disk}"

    local mount_point="/Volumes/${label}"
    if [[ ! -d "${mount_point}" ]]; then
        fail "Disk did not mount at ${mount_point}"
        exit 1
    fi

    ok "Formatted: ${mount_point}"
    echo ""

    # Init
    echo "  [2/2] Initializing chip..."
    echo ""
    "${CHIP_DIR}/init.sh" "${mount_point}" \
        --label "${label}" \
        --size "${vault_size}" \
        --model "${model_name}"

    echo ""
    ok "Chip ready: ${label}"
    echo ""
    echo -e "  ${C_DIM}next: jeff up ${label}${C_RESET}"
    echo ""
}

cmd_admin_init() {
    "${CHIP_DIR}/init.sh" "$@"
}

