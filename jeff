cmd_help() {
    echo -e "${C_DIM}${LOGO}${C_RESET}"
    echo -e "  ${C_BOLD}Always knows a guy.${C_RESET}"
    echo -e "  ${C_DIM}v${JEFF_VERSION} | Air-Gapped Tooling | 3DMATH${C_RESET}"
    echo ""
    echo "  Usage: jeff [command]"
    echo ""
    echo "  Chip Slot:"
    echo "    (no args)                Dashboard -- show slot state"
    echo "    up [LABEL]               Activate chip (scan + preflight + go)"
    echo "    down                     Deactivate (seal vault if open)"
    echo "    scan                     Detect chips on mounted volumes"
    echo "    check                    Verify chip presence"
    echo ""
    echo "  Vault:"
    echo "    mount                    Decrypt vault (read-only)"
    echo "    mount --read-write       Decrypt vault (read-write)"
    echo "    unmount                  Seal vault"
