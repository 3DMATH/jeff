    echo "    jeff deactivate"
    echo ""
}

# ============================================================
# VERSION
# ============================================================

cmd_version() {
    echo "jeff ${JEFF_VERSION}"
}

# ============================================================
# DISPATCH
# ============================================================

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "${COMMAND}" in
    scan)           cmd_scan ;;
    flash)          cmd_flash "$@" ;;
    activate)       cmd_activate "$@" ;;
    deactivate)     cmd_deactivate ;;
    mount)          cmd_mount "$@" ;;
    unmount)        cmd_unmount ;;
    flip)           cmd_flip ;;
    status)         cmd_status ;;
    init)           cmd_init "$@" ;;
    resolve)        cmd_resolve "$@" ;;
    midpoint)       cmd_midpoint "$@" ;;
    constellation)  cmd_constellation "$@" ;;
    version)        cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)
        fail "Unknown command: ${COMMAND}"
        cmd_help
        exit 1
        ;;
esac
