# ============================================================
# HELP
# ============================================================

cmd_help() {
    echo -e "${C_DIM}${LOGO}${C_RESET}"
    echo -e "  ${C_BOLD}Always knows a guy.${C_RESET}"
    echo -e "  ${C_DIM}v${JEFF_VERSION} | 3DMATH${C_RESET}"
    echo ""
    echo "  Jeff manages Booster Chips -- encrypted SD cards that give"
    echo "  your AI access to tools, data, and models. Plug in a chip,"
    echo "  Jeff scans it, confirms it is golden, and opens the MCP line."
    echo "  Pull it out, nothing breaks. Plug it back in, Jeff picks up"
    echo "  right where you left off."
    echo ""
    echo "  When a chip activates, a CueSheet appears in the cue-vox"
    echo "  menu named after the volume. Remove the chip, it disappears."
    echo ""
    echo "  Usage: jeff <command> [args]"
    echo ""
    echo "  Chip Management:"
    echo "    scan                     Detect chips on mounted volumes"
    echo "    flash <disk> [--label X] Erase disk + burn a fresh chip"
    echo "    init <path> [--label X]  Burn chip on formatted volume"
    echo "    activate <path>          Start MCP (no vault, no passphrase)"
    echo "    deactivate               Stop everything + clean up"
    echo "    mount [--read-write]     Decrypt vault for full access"
    echo "    unmount                  Seal vault (chip stays active)"
    echo "    flip                     Toggle read-only / read-write"
    echo "    status                   Show active chip info"
    echo ""
    echo "  Spectral Binding:"
    echo "    resolve <hex>            Resolve hex to spectral band"
    echo "    midpoint <hex> <hex>     Find midpoint between two colors"
    echo "    constellation <hex...>   Group colors by band proximity"
    echo ""
    echo "  Info:"
    echo "    version                  Show Jeff version"
    echo "    help                     Show this message"
    echo ""
    echo "  Quick Start:"
    echo "    1. Insert an SD card"
    echo "    2. jeff scan                    Find the chip"
    echo "    3. jeff activate /Volumes/NAME  Light it up"
    echo "    4. Open cue-vox -- the chip CueSheet is in the menu"
    echo ""
    echo "  Full Flow:"
