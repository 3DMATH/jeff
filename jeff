}

# ============================================================
# VERSION
# ============================================================

cmd_version() {
    echo "jeff ${JEFF_VERSION}"
}

# ============================================================
# DISPATCH
# ============================================================

COMMAND="${1:-dashboard}"
shift 2>/dev/null || true

case "${COMMAND}" in
    # Chip slot
    up)             cmd_up "$@" ;;
    down)           cmd_down ;;
    scan)           cmd_scan ;;
    check)          cmd_check ;;

    # Vault
    mount)          cmd_mount "$@" ;;
    unmount)        cmd_unmount ;;
    flip)           cmd_flip ;;

    # Diagnostics
    status)         cmd_status ;;
    preflight)      exec "${JEFF_DIR}/preflight" "$@" ;;

    # Spectral
    resolve)        cmd_resolve "$@" ;;
    midpoint)       cmd_midpoint "$@" ;;
    constellation)  cmd_constellation "$@" ;;

    # Admin (behind glass)
    admin)          cmd_admin "$@" ;;

    # Legacy aliases
    activate)       cmd_activate "$@" ;;
    deactivate)     cmd_deactivate ;;
    flash)
        echo ""
        fail "'jeff flash' has moved to 'jeff admin flash'"
        echo -e "  ${C_DIM}This is a destructive operation and requires the admin namespace.${C_RESET}"
        echo ""
        exit 1
        ;;
    init)
        echo ""
        fail "'jeff init' has moved to 'jeff admin init'"
        echo -e "  ${C_DIM}This is a destructive operation and requires the admin namespace.${C_RESET}"
        echo ""
        exit 1
        ;;

    # Dashboard (default)
    dashboard)      cmd_dashboard ;;

    # Info
    version)        cmd_version ;;
    help|--help|-h) cmd_help ;;

    *)
        fail "Unknown command: ${COMMAND}"
        echo ""
        echo "  Run 'jeff help' for usage."
        exit 1
        ;;
esac
