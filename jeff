#!/usr/bin/env bash
# ============================================================
#  JEFF -- Always knows a guy.
# ============================================================
#  Air-Gapped Tooling runtime. Manages Booster Chips -- encrypted
#  SD cards with models, data, and MCP servers on board.
#
#  Usage: jeff [command]
#
#  Chip Slot:
#    (no args)                Dashboard -- show slot state
#    up [LABEL]               Activate chip (scan + preflight + go)
#    down                     Deactivate (seal vault if open)
#    scan                     Detect chips on mounted volumes
#    check                    Verify chip presence
#
#  Vault:
#    mount                    Decrypt vault (read-only)
#    mount --read-write       Decrypt vault (read-write)
#    unmount                  Seal vault
#    flip                     Toggle read-only / read-write
#
#  Diagnostics:
#    status                   Detailed chip info
#    preflight                Validate MCP proxy before restart
#
#  Spectral:
#    resolve <hex>            Resolve hex to spectral band
#    midpoint <a> <b>         Find midpoint between two colors
#    constellation <hex...>   Group colors by band proximity
#
#  Admin (destructive -- requires confirmation):
#    admin flash <disk>       Erase disk + burn fresh chip
#    admin init <path>        Burn chip on formatted volume
#
#  Info:
#    version                  Show version
#    help                     Show this message
# ============================================================

set -euo pipefail

JEFF_VERSION="0.3.0"
JEFF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHIP_DIR="${JEFF_DIR}/chip"
SPECTRAL_DIR="${JEFF_DIR}/spectral"
STATE_FILE="${JEFF_DIR}/.jeff-state.json"
MCP_PID_FILE="${JEFF_DIR}/.jeff-mcp.pid"

LOGO='
       ██╗███████╗███████╗███████╗
       ██║██╔════╝██╔════╝██╔════╝
       ██║█████╗  █████╗  █████╗
  ██   ██║██╔══╝  ██╔══╝  ██╔══╝
  ╚█████╔╝███████╗██║     ██║
   ╚════╝ ╚══════╝╚═╝     ╚═╝
'

# ============================================================
# COLORS
# ============================================================

C_RESET="\033[0m"
C_BOLD="\033[1m"
C_DIM="\033[2m"
C_GREEN="\033[32m"
C_YELLOW="\033[33m"
C_BLUE="\033[34m"
C_RED="\033[31m"
C_CYAN="\033[36m"

info()  { echo -e "  ${C_BLUE}>>>${C_RESET} $1"; }
ok()    { echo -e "  ${C_GREEN}>>>${C_RESET} $1"; }
warn()  { echo -e "  ${C_YELLOW}>>>${C_RESET} $1"; }
fail()  { echo -e "  ${C_RED}>>>${C_RESET} $1"; }

# ============================================================
# HINT -- contextual next-action after every command
# ============================================================

_hint() {
    local state_mode="" state_label="" vault_mount=""

    if [[ -f "${STATE_FILE}" ]]; then
        state_mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode',''))" 2>/dev/null || echo "")
        state_label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null || echo "")
        vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")
    fi

    echo ""
    if [[ -z "${state_mode}" ]]; then
        echo -e "  ${C_DIM}next: jeff up             activate a chip${C_RESET}"
    elif [[ "${state_mode}" == "activated" ]]; then
        echo -e "  ${C_DIM}next: jeff mount          decrypt vault${C_RESET}"
        echo -e "  ${C_DIM}      jeff down           deactivate${C_RESET}"
    elif [[ "${state_mode}" == "read-only" ]]; then
        echo -e "  ${C_DIM}next: jeff flip           switch to read-write${C_RESET}"
        echo -e "  ${C_DIM}      jeff unmount        seal vault${C_RESET}"
        echo -e "  ${C_DIM}      jeff down           seal + deactivate${C_RESET}"
    elif [[ "${state_mode}" == "read-write" ]]; then
        echo -e "  ${C_DIM}next: jeff flip           switch to read-only${C_RESET}"
        echo -e "  ${C_DIM}      jeff unmount        seal vault${C_RESET}"
        echo -e "  ${C_DIM}      jeff down           seal + deactivate${C_RESET}"
    fi
}

# ============================================================
# HELPERS
# ============================================================

_verify_identity() {
    local heartbeat="$1"
    python3 - "${heartbeat}" << 'PYEOF'
import json, sys, hashlib
with open(sys.argv[1]) as f:
    chip = json.load(f)
if chip.get("format") != "booster-chip":
    print("FAIL|Not a booster chip")
    sys.exit(0)
if chip.get("protocol", 0) > 1:
    print("FAIL|Protocol version %s not supported" % chip.get("protocol"))
    sys.exit(0)
stored = chip.get("identity_hash", "")
if stored:
    copy = dict(chip)
    copy["identity_hash"] = ""
    computed = hashlib.sha256(json.dumps(copy, sort_keys=True, ensure_ascii=False).encode()).hexdigest()
    if computed != stored:
        print("FAIL|Identity tampered")
        sys.exit(0)
root = chip.get("tool_chain", {}).get("root", "#000000")
print("OK|%s|%s|%s|%s|%s" % (
    chip.get("device_id",""),
    chip.get("label",""),
    chip.get("model",""),
    root,
    chip.get("vault_volume_name",""),
))
PYEOF
}

_resolve_band() {
    python3 -c "import sys; sys.path.insert(0,'${SPECTRAL_DIR}'); from spectral import resolve; print(resolve('$1').get('band','?'))" 2>/dev/null || echo "?"
}

_check_presence() {
    # Returns 0 if chip is present, 1 if gone.
    # If gone and auto_deactivate=1, cleans up.
    local auto_deactivate="${1:-0}"

    if [[ ! -f "${STATE_FILE}" ]]; then
        return 1
    fi

    local volume_path
    volume_path=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path',''))" 2>/dev/null || echo "")

    if [[ -z "${volume_path}" ]]; then
        return 1
    fi

    # Check if the volume is still mounted
    if [[ -d "${volume_path}" ]] && [[ -f "${volume_path}/heartbeat.json" ]]; then
        return 0
    fi

    # Volume is gone
    if [[ "${auto_deactivate}" == "1" ]]; then
        local label mcp_pid vault_mount
        label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label','?'))" 2>/dev/null || echo "?")
        mcp_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")
        vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")

        # Kill MCP if running
        _kill_pid "${mcp_pid}"

        # Detach vault if mounted
        if [[ -n "${vault_mount}" ]] && [[ -d "${vault_mount}" ]]; then
            hdiutil detach "${vault_mount}" -force 2>/dev/null || true
        fi

        # Clean up state
        rm -f "${MCP_PID_FILE}" "${STATE_FILE}"

        warn "Auto-deactivated: ${label} (chip removed)"
    fi

    return 1
}

_kill_pid() {
    local pid="$1"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
        kill "${pid}" 2>/dev/null || true
        local i
        for i in 1 2 3 4 5; do
            kill -0 "${pid}" 2>/dev/null || return 0
            sleep 1
        done
        kill -9 "${pid}" 2>/dev/null || true
    fi
}

_start_mcp() {
    local volume="$1" device_id="$2" label="$3" model="$4" mode="$5"
    local vault_mount="${6:-}"

    export CHIP_DEVICE_ID="${device_id}"
    export CHIP_LABEL="${label}"
    export CHIP_VOLUME="${volume}"
    export CHIP_VAULT_MOUNT="${vault_mount}"
    export CHIP_MODEL="${model}"
    export CHIP_MODE="${mode}"

    # Always run MCP from the card
    local mcp_server="${volume}/mcp/server.py"
    if [[ ! -f "${mcp_server}" ]]; then
        mcp_server="${CHIP_DIR}/mcp_server.py"
        warn "No MCP on card -- using host copy"
    fi

    local mcp_log="${JEFF_DIR}/.jeff-mcp.log"
    python3 "${mcp_server}" </dev/null >"${mcp_log}" 2>&1 &
    local mcp_pid=$!
    echo "${mcp_pid}" > "${MCP_PID_FILE}"
    echo "${mcp_pid}"
}

_mcp_alive() {
    # Returns 0 if MCP process is alive, 1 if dead
    if [[ ! -f "${STATE_FILE}" ]]; then
        return 1
    fi
    local pid
    pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
        return 0
    fi
    return 1
}

# Scan volumes and return chip info lines: LABEL|PATH|ROOT|BAND|MOUNTS
_scan_volumes() {
    python3 - "${SPECTRAL_DIR}" << 'PYEOF'
import os, json, sys

spectral_dir = sys.argv[1]
sys.path.insert(0, spectral_dir)

try:
    from spectral import resolve
    HAS_SPECTRAL = True
except ImportError:
    HAS_SPECTRAL = False

volumes_dir = "/Volumes"
if not os.path.isdir(volumes_dir):
    sys.exit(0)

for name in sorted(os.listdir(volumes_dir)):
    vol = os.path.join(volumes_dir, name)
    hb = os.path.join(vol, "heartbeat.json")
    if not os.path.isfile(hb):
        continue
    try:
        with open(hb) as f:
            chip = json.load(f)
        root = chip.get("tool_chain", {}).get("root", "")
        band = ""
        if root and HAS_SPECTRAL:
            band = resolve(root).get("band", "")
        label = chip.get("label", name)
        mounts = chip.get("mount_count", 0)
        print("%s|%s|%s|%s|%d" % (label, vol, root or "-", band or "-", mounts))
    except Exception:
        continue
PYEOF
}

# ============================================================
# DASHBOARD -- jeff with no args
# ============================================================

cmd_dashboard() {
    echo ""
    echo -e "  ${C_BOLD}JEFF${C_RESET} ${C_DIM}v${JEFF_VERSION}${C_RESET}"
    echo ""

    # Check presence first (auto-deactivate if chip was removed)
    _check_presence 1 2>/dev/null || true

    if [[ -f "${STATE_FILE}" ]]; then
        # Chip is active -- show slot state
        local label mode root band volume vault_mount mcp_pid since
        label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label','?'))" 2>/dev/null || echo "?")
        mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode','?'))" 2>/dev/null || echo "?")
        root=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('root_color','?'))" 2>/dev/null || echo "?")
        band=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('band','?'))" 2>/dev/null || echo "?")
        volume=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path','?'))" 2>/dev/null || echo "?")
        vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")
        mcp_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")
        since=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('activated_at','?')[:16])" 2>/dev/null || echo "?")

        local mode_display="${mode}"
        if [[ "${mode}" == "activated" ]]; then
            mode_display="activated (vault sealed)"
        fi

        echo -e "  Slot:   ${C_CYAN}${label}${C_RESET}"
        echo -e "  Root:   ${C_CYAN}${root}${C_RESET} (${band})"
        echo -e "  Mode:   ${mode_display}"

        # Proxy health (can the MCP proxy module load?)
        if "${JEFF_DIR}/preflight" --quiet 2>/dev/null; then
            echo -e "  MCP:    ${C_GREEN}ready${C_RESET}"
        else
            echo -e "  MCP:    ${C_RED}BROKEN${C_RESET} (run jeff preflight)"
        fi

        if [[ -n "${vault_mount}" ]] && [[ -d "${vault_mount}" ]]; then
            echo -e "  Vault:  ${vault_mount}"
        fi

        echo -e "  Since:  ${since}"

        _hint
    else
        # No chip active -- scan for available chips
        local scan_output
        scan_output=$(_scan_volumes)

        if [[ -z "${scan_output}" ]]; then
            echo -e "  Slot:   ${C_DIM}empty${C_RESET}"
            echo ""
            echo -e "  ${C_DIM}Insert a chip, or:${C_RESET}"
            echo -e "  ${C_DIM}  jeff scan              detect chips${C_RESET}"
            echo -e "  ${C_DIM}  jeff admin flash       burn a new chip${C_RESET}"
        else
            echo -e "  Slot:   ${C_DIM}empty${C_RESET}"
            echo ""

            local count=0
            local single_label="" single_path=""
            while IFS='|' read -r clabel cpath croot cband cmounts; do
                echo -e "  Found:  ${C_CYAN}${clabel}${C_RESET} at ${cpath} ${C_DIM}(${croot} / ${cband})${C_RESET}"
                single_label="${clabel}"
                single_path="${cpath}"
                count=$((count + 1))
            done <<< "${scan_output}"

            echo ""
            if [[ "${count}" -eq 1 ]]; then
                echo -e "  ${C_DIM}jeff up              activate ${single_label}${C_RESET}"
            else
                echo -e "  ${C_DIM}jeff up LABEL         activate a chip${C_RESET}"
            fi
        fi
    fi

    echo ""
}

# ============================================================
# UP -- smart activate (scan + preflight + activate)
# ============================================================

cmd_up() {
    local target="${1:-}"

    # If chip is already active, check MCP health
    if [[ -f "${STATE_FILE}" ]]; then
        local current_label
        current_label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null || echo "")

        # Check if chip is still present
        if ! _check_presence 1; then
            # Chip was removed, state cleaned up -- fall through to activate
            :
        elif _mcp_alive; then
            ok "${current_label} is up and running"
            _hint
            return 0
        else
            # MCP dead but chip present -- restart it
            info "MCP dead, restarting..."
            local volume_path device_id model mode vault_mount old_pid
            volume_path=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path',''))" 2>/dev/null)
            device_id=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('device_id',''))" 2>/dev/null)
            model=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('model',''))" 2>/dev/null)
            mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode','activated'))" 2>/dev/null)
            vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")
            old_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")

            _kill_pid "${old_pid}"
            local mcp_pid
            mcp_pid=$(_start_mcp "${volume_path}" "${device_id}" "${current_label}" "${model}" "${mode}" "${vault_mount}")

            # Update PID in state
            python3 - "${STATE_FILE}" "${mcp_pid}" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    state = json.load(f)
state["mcp_pid"] = int(sys.argv[2])
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

            ok "${current_label} MCP restarted (PID ${mcp_pid})"
            _hint
            return 0
        fi
    fi

    # Run silent preflight
    if [[ -x "${JEFF_DIR}/preflight" ]]; then
        if ! "${JEFF_DIR}/preflight" --quiet 2>/dev/null; then
            fail "Preflight failed. Run 'jeff preflight' for details."
            exit 1
        fi
    fi

    # Find the chip to activate
    local volume_path=""

    if [[ -n "${target}" ]]; then
        # Explicit target -- could be a label or a path
        if [[ -d "${target}" ]] && [[ -f "${target}/heartbeat.json" ]]; then
            volume_path="${target}"
        elif [[ -d "/Volumes/${target}" ]] && [[ -f "/Volumes/${target}/heartbeat.json" ]]; then
            volume_path="/Volumes/${target}"
        else
            fail "No chip found at ${target}"
            exit 1
        fi
    else
        # No target -- scan and auto-select if exactly one
        local scan_output
        scan_output=$(_scan_volumes)

        if [[ -z "${scan_output}" ]]; then
            echo ""
            warn "No chips detected. Insert an SD card."
            echo ""
            exit 1
        fi

        local count=0
        local found_label="" found_path=""
        while IFS='|' read -r clabel cpath croot cband cmounts; do
            found_label="${clabel}"
            found_path="${cpath}"
            count=$((count + 1))
        done <<< "${scan_output}"

        if [[ "${count}" -eq 1 ]]; then
            volume_path="${found_path}"
        else
            echo ""
            warn "Multiple chips detected. Specify which one:"
            echo ""
            while IFS='|' read -r clabel cpath croot cband cmounts; do
                echo -e "  ${C_CYAN}${clabel}${C_RESET}  ${cpath}  ${C_DIM}(${croot})${C_RESET}"
            done <<< "${scan_output}"
            echo ""
            echo "  jeff up LABEL"
            echo ""
            exit 1
        fi
    fi

    # Activate
    cmd_activate "${volume_path}"
}

# ============================================================
# DOWN -- smart deactivate (seal vault if open, then deactivate)
# ============================================================

cmd_down() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        warn "No chip active."
        return 0
    fi

    # Check if chip was already removed
    if ! _check_presence 1; then
        ok "Cleaned up. Slot empty."
        return 0
    fi

    cmd_deactivate
}

# ============================================================
# SCAN
# ============================================================

cmd_scan() {
    echo -e "${C_BOLD}  Scanning for chips${C_RESET}"
    echo ""

    python3 - "${SPECTRAL_DIR}" << 'PYEOF'
import os, json, sys

spectral_dir = sys.argv[1]
sys.path.insert(0, spectral_dir)

try:
    from spectral import resolve
    HAS_SPECTRAL = True
except ImportError:
    HAS_SPECTRAL = False

volumes_dir = "/Volumes"
found = []

if os.path.isdir(volumes_dir):
    for name in sorted(os.listdir(volumes_dir)):
        vol = os.path.join(volumes_dir, name)
        hb = os.path.join(vol, "heartbeat.json")
        if not os.path.isfile(hb):
            continue
        try:
            with open(hb) as f:
                chip = json.load(f)
            root = chip.get("tool_chain", {}).get("root", "")
            band = ""
            if root and HAS_SPECTRAL:
                band = resolve(root).get("band", "")
            found.append({
                "label": chip.get("label", name),
                "device": chip.get("device_id", "?")[:8],
                "root": root or "-",
                "band": band or "-",
                "mounts": chip.get("mount_count", 0),
                "path": vol,
            })
        except Exception:
            continue

if not found:
    print("  No chips detected. Insert an SD card with heartbeat.json.")
    exit(0)

print("  %-10s %-8s %-9s %-12s %4s  %s" % ("Label", "Device", "Root", "Band", "Mnts", "Path"))
print("  " + "-" * 65)
for c in found:
    print("  %-10s %-8s %-9s %-12s %4d  %s" % (
        c["label"][:10], c["device"], c["root"][:9], c["band"][:12], c["mounts"], c["path"]
    ))

if len(found) > 1 and HAS_SPECTRAL:
    from spectral import constellation_summary
    roots = [c["root"] for c in found if c["root"] != "-"]
    if roots:
        print("")
        print("  Constellation: %s" % constellation_summary(roots))
PYEOF

    _hint
}

# ============================================================
# ACTIVATE (called by cmd_up, also available directly)
# ============================================================

cmd_activate() {
    local volume="${1:?Usage: jeff activate /Volumes/NAME}"

    if [[ ! -f "${volume}/heartbeat.json" ]]; then
        fail "No heartbeat.json at ${volume}"
        exit 1
    fi

    if [[ -f "${STATE_FILE}" ]]; then
        local current
        current=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null || echo "")
        if [[ -n "${current}" ]]; then
            fail "Already active: ${current}. Run 'jeff down' first."
            exit 1
        fi
    fi

    # Verify identity
    local chip_info
    chip_info=$(_verify_identity "${volume}/heartbeat.json")

    if [[ "${chip_info}" == FAIL* ]]; then
        fail "${chip_info#FAIL|}"
        exit 1
    fi

    local device_id label model root_color vault_vol
    device_id=$(echo "${chip_info}" | cut -d'|' -f2)
    label=$(echo "${chip_info}" | cut -d'|' -f3)
    model=$(echo "${chip_info}" | cut -d'|' -f4)
    root_color=$(echo "${chip_info}" | cut -d'|' -f5)
    vault_vol=$(echo "${chip_info}" | cut -d'|' -f6)

    local band
    band=$(_resolve_band "${root_color}")

    echo ""
    echo -e "  ${C_BOLD}Activating${C_RESET}"
    echo -e "  Label:    ${C_CYAN}${label}${C_RESET}"
    echo -e "  Device:   ${device_id:0:8}"
    echo -e "  Root:     ${C_CYAN}${root_color}${C_RESET} (${band})"
    echo ""

    # Start MCP
    local mcp_pid
    mcp_pid=$(_start_mcp "${volume}" "${device_id}" "${label}" "${model}" "activated")
    ok "MCP server (PID ${mcp_pid})"

    # Write state
    python3 - "${STATE_FILE}" "${device_id}" "${label}" "${volume}" "${mcp_pid}" "${model}" "${root_color}" "${band}" "${vault_vol}" << 'PYEOF'
import json, sys
from datetime import datetime, timezone
path = sys.argv[1]
state = {
    "device_id": sys.argv[2], "label": sys.argv[3], "volume_path": sys.argv[4],
    "vault_mount": "", "mcp_pid": int(sys.argv[5]), "model": sys.argv[6],
    "mode": "activated", "root_color": sys.argv[7], "band": sys.argv[8],
    "vault_volume_name": sys.argv[9],
    "activated_at": datetime.now(timezone.utc).isoformat()
}
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    echo ""
    echo -e "  ${C_GREEN}Active: ${label} ${C_DIM}[${root_color}]${C_RESET}"

    _hint
}

# ============================================================
# DEACTIVATE
# ============================================================

cmd_deactivate() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        warn "No chip active."
        return 0
    fi

    local label mcp_pid mode vault_mount volume_path
    label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label','?'))" 2>/dev/null || echo "?")
    mcp_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")
    mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode',''))" 2>/dev/null || echo "")
    vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")
    volume_path=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path',''))" 2>/dev/null || echo "")

    echo ""
    echo -e "  ${C_BOLD}Deactivating: ${label}${C_RESET}"
    echo ""

    # If vault is mounted, unmount it first
    if [[ -n "${vault_mount}" ]] && [[ -d "${vault_mount}" ]]; then
        info "Sealing vault..."
        sync
        hdiutil detach "${vault_mount}" -quiet 2>/dev/null || {
            warn "Clean detach failed -- forcing..."
            hdiutil detach "${vault_mount}" -force 2>/dev/null || true
        }
        ok "Vault sealed"
    fi

    # Stop MCP
    _kill_pid "${mcp_pid}"
    ok "MCP stopped"

    rm -f "${MCP_PID_FILE}" "${STATE_FILE}"

    ok "Deactivated: ${label}"

    _hint
}

# ============================================================
# MOUNT (decrypt vault)
# ============================================================

cmd_mount() {
    local mount_mode="read-only"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --read-write) mount_mode="read-write"; shift ;;
            *)            echo "Unknown arg: $1"; exit 1 ;;
        esac
    done

    if [[ ! -f "${STATE_FILE}" ]]; then
        fail "No chip active. Run 'jeff up' first."
        exit 1
    fi

    # Presence guard
    if ! _check_presence 1; then
        exit 1
    fi

    local volume_path vault_volume_name device_id label model current_mode
    volume_path=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path',''))" 2>/dev/null)
    vault_volume_name=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_volume_name',''))" 2>/dev/null)
    device_id=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('device_id',''))" 2>/dev/null)
    label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null)
    model=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('model',''))" 2>/dev/null)
    current_mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode',''))" 2>/dev/null)

    if [[ "${current_mode}" == "read-only" ]] || [[ "${current_mode}" == "read-write" ]]; then
        fail "Vault already mounted in ${current_mode} mode. Use 'jeff flip' or 'jeff unmount'."
        exit 1
    fi

    if [[ ! -f "${volume_path}/vault.sparseimage" ]]; then
        fail "No vault.sparseimage at ${volume_path}"
        exit 1
    fi

    echo ""
    echo -e "  ${C_BOLD}Mounting vault: ${label}${C_RESET}"
    echo -e "  Mode: ${mount_mode}"
    echo ""

    # Decrypt vault
    read -rsp "  Passphrase: " VAULT_PASS
    echo ""

    echo "${VAULT_PASS}" | hdiutil attach "${volume_path}/vault.sparseimage" -stdinpass -quiet 2>/dev/null || {
        echo ""
        warn "Retrying..."
        read -rsp "  Passphrase: " VAULT_PASS
        echo ""
        echo "${VAULT_PASS}" | hdiutil attach "${volume_path}/vault.sparseimage" -stdinpass || {
            fail "Could not mount vault"
            exit 1
        }
    }

    local vault_mount="/Volumes/${vault_volume_name}"
    if [[ ! -d "${vault_mount}" ]]; then
        fail "Vault did not mount at ${vault_mount}"
        exit 1
    fi

    ok "Vault mounted at ${vault_mount}"

    # Increment mount count
    python3 - "${volume_path}/heartbeat.json" << 'PYEOF'
import json, sys, hashlib
path = sys.argv[1]
with open(path) as f:
    chip = json.load(f)
chip["mount_count"] = chip.get("mount_count", 0) + 1
chip["identity_hash"] = ""
canonical = json.dumps(chip, sort_keys=True, ensure_ascii=False)
chip["identity_hash"] = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
with open(path, "w") as f:
    json.dump(chip, f, indent=2)
print("  Mount #%d" % chip["mount_count"])
PYEOF

    # Restart MCP with vault access
    local old_pid
    old_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")
    _kill_pid "${old_pid}"

    local mcp_pid
    mcp_pid=$(_start_mcp "${volume_path}" "${device_id}" "${label}" "${model}" "${mount_mode}" "${vault_mount}")
    ok "MCP restarted with vault (PID ${mcp_pid})"

    # Update state
    python3 - "${STATE_FILE}" "${vault_mount}" "${mount_mode}" "${mcp_pid}" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    state = json.load(f)
state["vault_mount"] = sys.argv[2]
state["mode"] = sys.argv[3]
state["mcp_pid"] = int(sys.argv[4])
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    echo ""
    echo -e "  ${C_GREEN}Mounted: ${label} [${mount_mode}]${C_RESET}"

    _hint
}

# ============================================================
# UNMOUNT (seal vault, keep chip active)
# ============================================================

cmd_unmount() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        warn "No chip active."
        return 0
    fi

    local vault_mount label mcp_pid
    vault_mount=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('vault_mount',''))" 2>/dev/null || echo "")
    label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null || echo "?")
    mcp_pid=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mcp_pid',''))" 2>/dev/null || echo "")

    if [[ -z "${vault_mount}" ]] || [[ ! -d "${vault_mount}" ]]; then
        warn "No vault mounted."
        return 0
    fi

    echo ""
    echo -e "  ${C_BOLD}Unmounting vault: ${label}${C_RESET}"
    echo ""

    # Restart MCP without vault
    _kill_pid "${mcp_pid}"

    local volume_path device_id model
    volume_path=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('volume_path',''))" 2>/dev/null)
    device_id=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('device_id',''))" 2>/dev/null)
    model=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('model',''))" 2>/dev/null)

    # Detach vault
    sync
    hdiutil detach "${vault_mount}" -quiet 2>/dev/null || {
        warn "Clean detach failed -- forcing..."
        hdiutil detach "${vault_mount}" -force 2>/dev/null || true
    }
    ok "Vault sealed"

    # Restart MCP in activated mode (no vault)
    local new_pid
    new_pid=$(_start_mcp "${volume_path}" "${device_id}" "${label}" "${model}" "activated")
    ok "MCP restarted without vault (PID ${new_pid})"

    # Update state
    python3 - "${STATE_FILE}" "${new_pid}" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    state = json.load(f)
state["vault_mount"] = ""
state["mode"] = "activated"
state["mcp_pid"] = int(sys.argv[2])
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    echo ""
    echo -e "  ${C_GREEN}Vault sealed. ${label} still active.${C_RESET}"

    _hint
}

# ============================================================
# FLIP (toggle read-only / read-write)
# ============================================================

cmd_flip() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        fail "No chip active."
        exit 1
    fi

    local current_mode label
    current_mode=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('mode',''))" 2>/dev/null)
    label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label',''))" 2>/dev/null)

    if [[ "${current_mode}" == "activated" ]]; then
        fail "Vault not mounted. Run 'jeff mount' first."
        exit 1
    fi

    local new_mode
    if [[ "${current_mode}" == "read-only" ]]; then
        new_mode="read-write"
        echo ""
        echo "  Switching to READ-WRITE."
        read -rp "  Confirm? (yes/no): " CONFIRM
        if [[ "${CONFIRM}" != "yes" ]]; then
            echo "  Cancelled."
            return
        fi
    else
        new_mode="read-only"
    fi

    python3 - "${STATE_FILE}" "${new_mode}" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    state = json.load(f)
state["mode"] = sys.argv[2]
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    export CHIP_MODE="${new_mode}"
    ok "${label}: ${new_mode}"

    _hint
}

# ============================================================
# CHECK
# ============================================================

cmd_check() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        echo ""
        warn "No chip active."
        echo ""
        return
    fi

    if _check_presence 1; then
        local label
        label=$(python3 -c "import json; print(json.load(open('${STATE_FILE}')).get('label','?'))" 2>/dev/null || echo "?")
        ok "${label} present"
    fi
}

# ============================================================
# STATUS
# ============================================================

cmd_status() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        echo ""
        warn "No chip active."
        echo ""
        return
    fi

    # Presence guard: auto-deactivate if volume is gone
    if ! _check_presence 1; then
        return
    fi

    python3 - "${STATE_FILE}" << 'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    s = json.load(f)
print("")
print("  Label:      %s" % s.get("label", "?"))
print("  Device:     %s" % s.get("device_id", "?")[:8])
print("  Mode:       %s" % s.get("mode", "?"))
print("  Root:       %s (%s)" % (s.get("root_color", "?"), s.get("band", "?")))
print("  Volume:     %s" % s.get("volume_path", "?"))
vault = s.get("vault_mount", "")
if vault:
    print("  Vault:      %s" % vault)
print("  Model:      %s" % (s.get("model") or "(none)"))
mcp = s.get("mcp_pid", "")
if mcp:
    import os
    try:
        os.kill(int(mcp), 0)
        print("  MCP:        running (PID %s)" % mcp)
    except (OSError, ValueError):
        print("  MCP:        stopped")
print("  Since:      %s" % s.get("activated_at", "?")[:16])
print("")
PYEOF

    _hint
}

